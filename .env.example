EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for quiz question seed script (npm run seed:quiz). Get from Supabase Dashboard → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: for deploying Edge Functions (get token from https://supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx
